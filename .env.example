PORT=3000
GROQ_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
DATABASE_PATH=./data/orders.db

# Required for pnpm setup:webhook (Meta App settings → Basic → App secret)
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=

# Optional: override auto-detected ngrok URL
# WEBHOOK_URL=https://abc123.ngrok-free.app/webhook

# ngrok local API (default — no change needed when running ngrok in another terminal)
NGROK_API_URL=http://127.0.0.1:4040
